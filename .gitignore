# ========== Java后端相关 ==========
# 编译后的class文件和jar包
target/
*.class
*.jar
*.war

# IDEA配置文件（每个人的配置不一样，不需要上传）
.idea/
*.iml
*.ipr
*.iws

# 日志文件
logs/
*.log

# 本地上传的文件（不需要传到GitHub）
uploads/

# ========== 前端相关 ==========
# 依赖包（原生JS没有的话也不影响）
node_modules/

# VSCode配置
.vscode/

# ========== 系统通用 ==========
# Windows系统缩略图缓存
Thumbs.db
# Mac系统文件
.DS_Store

# 临时文件
*.tmp
*.temp